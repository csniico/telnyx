# ---- Server-only secrets (NO NEXT_PUBLIC_ prefix so they never reach the browser) ----

# Telnyx API key (Mission Control > API Keys). Starts with "KEY".
TELNYX_API_KEY=KEY01...

# Telnyx account public key (Mission Control > Keys & Credentials > Public Key).
# Base64, used to verify Ed25519 webhook signatures. Required in production.
TELNYX_PUBLIC_KEY=

# MongoDB connection string (e.g. MongoDB Atlas SRV URI).
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# Optional: database name (defaults to "telnyx_admin").
MONGODB_DB=telnyx_admin

# Optional: reject webhooks whose timestamp is older than this many seconds (replay protection).
WEBHOOK_TOLERANCE_SECONDS=300